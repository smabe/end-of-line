__pycache__/
*.pyc
*.egg-info/
.venv/
.eggs/
build/
dist/
.pytest_cache/
.coverage
.DS_Store

# clu runtime state — per-project state files, logs, and local config.
# Use examples/HealthData.orchestrator.json as the template.
.orchestrator.json
**/.orchestrator/

# Claude Code session state (transcripts, snapshots). Not source.
.claude/

# graphify knowledge graph — regenerated on every commit by the
# post-commit hook (`graphify hook install`). Not source.
graphify-out/

# Ruff cache — regenerated per-machine.
.ruff_cache/
# jscpd JSON-reporter output, regenerated on demand.
report/
