<?xml version="1.0" encoding="UTF-8"?>
<!--
  LaunchAgent template for the clu tick driver.

  Install:
    1. Copy to ~/Library/LaunchAgents/com.clu.tick.plist
    2. Verify the ProgramArguments path matches `which clu` in your shell
       (pipx installs to ~/.local/bin/clu by default). LaunchAgents do
       NOT inherit $PATH, so the absolute path is required.
    3. launchctl bootstrap gui/$UID ~/Library/LaunchAgents/com.clu.tick.plist
    4. Tail /tmp/clu-tick.{out,err} to watch each tick.

  StartInterval=60 fires `clu tick-all` every minute. The subcommand
  iterates the host registry and ticks each registered plan once. Plans
  with no pending work return [idle] (cheap — registry walk + state read);
  plans with a phase ready spawn a worker via the configured
  dispatch.command. Costs roughly: one claude --print session per active
  plan per dispatch, capped at the budget in .orchestrator.json. Idle
  ticks are essentially free, so tightening the cadence speeds up phase-
  to-phase chaining without meaningful resource cost.

  Dial up to 300 if you prefer the legacy 5-minute cadence (lower log
  noise in /tmp/clu-tick.out) or down to 30 for tighter feedback during
  active development.

  Pre-Day-3.5 installs used examples/clu-tick-all.sh as ProgramArguments.
  That path now exec's `clu tick-all` as a back-compat shim; re-bootstrap
  with this template to drop the shell hop.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.clu.tick</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/smabe/.local/bin/clu</string>
        <string>tick-all</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/clu-tick.out</string>

    <key>StandardErrorPath</key>
    <string>/tmp/clu-tick.err</string>
</dict>
</plist>
